# Telegram bot token from @BotFather
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Public HTTPS base URL of the server that will host the webhook
# (no trailing slash), e.g. https://mybot.example.com
WEBHOOK_URL=https://mybot.example.com

# Port the Express server listens on
PORT=3000

# Store / shop information shown to the user
STORE_NAME=My Store
STORE_PHONE=+998901234567
STORE_LATITUDE=41.311081
STORE_LONGITUDE=69.240562
YANDEX_MAPS_URL=https://yandex.com/maps/?pt=69.240562,41.311081&z=17

# Bitrix24 Local Application credentials (Developer resources -> Other ->
# Local application). Install handler URL must be set in Bitrix to:
#   <WEBHOOK_URL>/bitrix/install
BITRIX_CLIENT_ID=local.xxxxxxxxxxxxxxxx.xxxxxxxx
BITRIX_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bitrix24 Open Line ID to attach the Telegram connector to
# (Контакт-центр / Contact Center -> Открытые линии -> Open Line ID)
BITRIX_LINE_ID=2
