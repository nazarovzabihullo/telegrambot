# Telegram bot token from @BotFather
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Public HTTPS base URL of the server that will host the webhook
# (no trailing slash), e.g. https://mybot.example.com
WEBHOOK_URL=https://mybot.example.com

# Port the Express server listens on
PORT=3000

# Store / shop information shown to the user
STORE_NAME=My Store
STORE_PHONE=+998901234567
STORE_LATITUDE=41.311081
STORE_LONGITUDE=69.240562
YANDEX_MAPS_URL=https://yandex.com/maps/?pt=69.240562,41.311081&z=17

# Bitrix24 incoming webhook URL used to forward ordinary chat messages
# e.g. https://your-domain.bitrix24.com/rest/1/xxxxxxxxxxxxxxxx/
BITRIX_WEBHOOK=https://your-domain.bitrix24.com/rest/1/xxxxxxxxxxxxxxxx/
